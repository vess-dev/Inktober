//========================================================================================================================
// Imports.

import com.hamoid.*;
import gifAnimation.*;

//========================================================================================================================
// Template globals.

int WINDOW_SIZE = 600;
String WINDOW_TITLE = "Day 1: \"\"";
String FILE_TITLE = "Day01Dream.mp4";
VideoExport video_handle;
int video_toggle;

//========================================================================================================================
// Sketch globals.



//========================================================================================================================
// Classes.



//========================================================================================================================
// Describe the sketch.

void settings() {
  size(WINDOW_SIZE, WINDOW_SIZE);
}

//========================================================================================================================
// One time sketch setup.

void setup() {
  surface.setTitle(WINDOW_TITLE);
  background(255);
  noStroke();
  video_handle = new VideoExport(this, FILE_TITLE);
  video_toggle = 0;
}

//========================================================================================================================
// Draw loop per frame.

void draw() {
  background(255);
  if (video_toggle == 1) {
    video_handle.saveFrame();
  } else if (video_toggle == 2) {
    video_handle.endMovie();
    exit();
  }
}

//========================================================================================================================
// Finish with the sketch.

void mousePressed() {
  if (video_toggle == 0) {
    video_handle.startMovie();
    video_toggle = 1;
  } else if (video_toggle == 1) {
    video_toggle = 2;
  }
}

